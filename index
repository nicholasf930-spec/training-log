// Tiny markdown -> HTML converter (handles common patterns)
function renderMarkdown(md) {
  if (!md) return '';
  let html = md;
  // Escape HTML first
  html = html.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  // Headers
  html = html.replace(/^### (.+)$/gm, '<h3>$1</h3>');
  html = html.replace(/^## (.+)$/gm, '<h2>$1</h2>');
  html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');
  // Bold and italic
  html = html.replace(/\*\*([^*]+?)\*\*/g, '<strong>$1</strong>');
  html = html.replace(/(?<!\*)\*([^*\n]+?)\*(?!\*)/g, '<em>$1</em>');
  // Inline code
  html = html.replace(/`([^`]+?)`/g, '<code>$1</code>');
  // Lists - process line by line
  const lines = html.split('\n');
  const out = [];
  let inUl = false, inOl = false;
  for (const line of lines) {
    const ulMatch = line.match(/^[-*]\s+(.+)$/);
    const olMatch = line.match(/^\d+\.\s+(.+)$/);
    if (ulMatch) {
      if (!inUl) { out.push('<ul>'); inUl = true; }
      if (inOl) { out.push('</ol>'); inOl = false; }
      out.push('<li>' + ulMatch[1] + '</li>');
    } else if (olMatch) {
      if (!inOl) { out.push('<ol>'); inOl = true; }
      if (inUl) { out.push('</ul>'); inUl = false; }
      out.push('<li>' + olMatch[1] + '</li>');
    } else {
      if (inUl) { out.push('</ul>'); inUl = false; }
      if (inOl) { out.push('</ol>'); inOl = false; }
      out.push(line);
    }
  }
  if (inUl) out.push('</ul>');
  if (inOl) out.push('</ol>');
  html = out.join('\n');
  // Paragraphs - wrap consecutive non-tag lines
  html = html.split(/\n\n+/).map(block => {
    if (block.trim().startsWith('<') || !block.trim()) return block;
    return '<p>' + block.replace(/\n/g, '<br>') + '</p>';
  }).join('\n');
  return html;
}

function buildWeeklySummary() {
  // Build the prompt context for Claude
  const today = new Date();
  const weekAgo = new Date(today); weekAgo.setDate(today.getDate() - 7);
  const weekStartStr = weekAgo.toISOString().slice(0,10);

  // 1. Body weight changes
  const recentBody = bodyLog.filter(e => e.date >= weekStartStr).sort((a,b)=>a.date.localeCompare(b.date));
  const earliestBody = bodyLog.filter(e => e.date < weekStartStr).slice(-1)[0];
  const weightLine = recentBody.length ? (() => {
    const start = earliestBody?.weight || recentBody[0].weight;
    const end = recentBody[recentBody.length-1].weight;
    const diff = end - start;
    return `Weight: ${recentBody.length} entries, ${start} → ${end} lb (${diff>0?'+':''}${diff.toFixed(1)} lb)`;
  })() : 'Weight: no entries this week';

  // 2. Workouts logged in exHist (only this week's snapshots)
  const recentLifts = [];
  Object.entries(exHist).forEach(([exId, hist]) => {
    const last = hist[hist.length-1];
    if (last && last.week === plan.week - 1) { // last week's snapshot
      const ex = plan.days.flatMap(d=>d.exercises).find(e=>e.id===exId);
      const muscle = ex?.muscle || 'unknown';
      recentLifts.push({
        name: last.exName,
        muscle,
        sets: last.sets,
        vol: last.vol,
        notes: last.notes
      });
    }
  });

  // 3. Volume by muscle
  const volByMuscle = {};
  recentLifts.forEach(l => {
    volByMuscle[l.muscle] = (volByMuscle[l.muscle] || 0) + (l.sets?.length || 0);
  });

  // 4. Nutrition - days hit calorie & protein targets
  const lastBody = bodyLog.slice(-1)[0];
  const weight = lastBody?.weight || profile.weight || 0;
  const proteinTarget = Math.round(weight);
  const tdee = calcTDEE({...profile, weight});
  const calTarget = calcCalGoal(profile, tdee);
  const dayResults = [];
  for (let i = 6; i >= 0; i--) {
    const d = new Date(today); d.setDate(today.getDate() - i);
    const dStr = d.toISOString().slice(0,10);
    const meals = mealLogs[dStr] || [];
    const cal = meals.reduce((a,m)=>a+(+m.cal||0),0);
    const prot = meals.reduce((a,m)=>a+(+(m.protein||m.p)||0),0);
    if (cal > 0 || prot > 0) {
      dayResults.push({date: dStr, cal, prot,
        proteinHit: prot >= proteinTarget,
        calOnTarget: calTarget && Math.abs(cal - calTarget) <= 200
      });
    }
  }

  // 5. Runs
  const recentRuns = [];
  Object.entries(runLogs||{}).forEach(([slotId, runs]) => {
    runs.filter(r => r.date >= weekStartStr).forEach(r => recentRuns.push(r));
  });

  // 6. Phase
  const phaseInfo = phase ? `Active phase: ${phase.type}, ${phase.startWeight} → ${phase.goalWeight} lb over ${phase.durationWeeks} weeks (started ${phase.startDate})` : 'No active cut/bulk phase';

  // Build text summary
  const summary = `# Weekly Training & Nutrition Summary

## Body
${weightLine}
${recentBody.length>0 && recentBody.find(e=>e.bf) ? `Body fat range: ${recentBody.filter(e=>e.bf).map(e=>e.bf+'%').join(', ')}` : 'No body fat data'}

## Goal & Phase
${phaseInfo}
Daily calorie target: ${calTarget || '—'} kcal
Daily protein target: ${proteinTarget || '—'} g
Mode: ${profile.goalMode || 'maintain'} (${profile.goalRate || 0.5} lb/wk)

## Training (last week's logged sessions)
${recentLifts.length ? recentLifts.map(l => `- ${l.name} (${l.muscle}): ${l.sets.map(s=>s.w?s.w+'×'+s.r:s.r+' reps').join(', ')} = ${l.vol} vol${l.notes?` — "${l.notes}"`:''}`).join('\n') : 'No completed sessions logged'}

## Volume by Muscle (sets last week)
${Object.entries(volByMuscle).length ? Object.entries(volByMuscle).map(([m,v])=>`- ${m}: ${v} sets`).join('\n') : 'No volume tracked'}

## Nutrition (last 7 days)
${dayResults.length ? dayResults.map(d => `- ${d.date}: ${d.cal} kcal${calTarget?` (${d.cal-calTarget>0?'+':''}${d.cal-calTarget})`:''} | ${d.prot}g protein${d.proteinHit?' ✓':' ✗'}`).join('\n') : 'No meals logged'}
Days protein target hit: ${dayResults.filter(d=>d.proteinHit).length} / ${dayResults.length || 0}

## Runs (this week)
${recentRuns.length ? recentRuns.map(r => `- ${r.date}: ${r.distance||'—'} mi ${r.duration?`in ${r.duration}min`:''} (${r.intensity||'no type'})${r.notes?` — "${r.notes}"`:''}`).join('\n') : 'No runs logged'}
`;

  return summary;
}

async function generateWeeklyReview() {
  const btn = document.getElementById('genReviewBtn');
  const label = document.getElementById('genReviewLabel');
  const status = document.getElementById('reviewStatus');
  const contentEl = document.getElementById('reviewContent');

  if (btn) btn.disabled = true;
  if (label) label.textContent = 'Thinking...';
  if (contentEl) {
    contentEl.innerHTML = `<div class="review-loading"><div class="review-spinner"></div><span>Claude is reviewing your week...</span></div>`;
  }
  if (status) {
    status.style.display = 'block';
    status.textContent = 'Building summary from your data...';
  }

  try {
    const summary = buildWeeklySummary();
    if (status) status.textContent = 'Sending to Claude...';

    const systemPrompt = `You are an experienced strength coach and nutrition advisor reviewing a client's weekly training and nutrition data. Your client is a serious lifter who values evidence-based recommendations.

Your tone is direct, knowledgeable, supportive but not sycophantic. You give specific, actionable observations — not generic encouragement. You speak like a coach who actually cares about results, not a wellness app.

Format your response as markdown with these sections:
## What went well
2-3 specific bullets about what they did right this week.

## What needs attention
2-3 specific bullets about gaps, missed targets, or concerning trends. Be honest but constructive.

## Focus for next week
2-3 specific, prioritized action items. Tell them exactly what to do, not vague suggestions.

Keep the entire response under 300 words. Be specific — reference actual numbers from their data. If data is missing, note it briefly but don't dwell on it. Don't use phrases like "great job" or "keep it up". Talk to them like a coach would.`;

    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: systemPrompt,
        messages: [{role:'user', content: summary}]
      })
    });

    if (!resp.ok) {
      const errText = await resp.text();
      throw new Error('API error: ' + resp.status + ' ' + errText.slice(0, 200));
    }

    const data = await resp.json();
    const reviewText = data.content?.find(b => b.type === 'text')?.text || 'No response generated.';

    _lastReview = {
      generatedAt: new Date().toISOString(),
      content: reviewText,
      weekKey: getWeekKey(todayStr())
    };
    await saveLastReview();
    if (status) status.style.display = 'none';
    renderReviewPanel();
    toast('Review ready');
  } catch(err) {
    console.error('Review error:', err);
    if (contentEl) {
      contentEl.innerHTML = `<div class="card" style="padding:16px"><div style="font-size:13px;color:var(--danger);margin-bottom:6px">Couldn't generate review</div><div style="font-size:11px;color:var(--t3);line-height:1.5">${esc(err.message || 'Unknown error')}</div></div>`;
    }
    if (status) status.style.display = 'none';
  } finally {
    if (btn) btn.disabled = false;
    if (label) label.textContent = _lastReview ? 'Regenerate' : 'Generate';
  }
}


