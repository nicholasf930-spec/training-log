async function exportData() {
  const keys = ['plan','logs','exhist','profile','bodylog','meals','photos','phase','runlogs','customFoods','mealTemplates'];
  const backup = { version: 1, exported: new Date().toISOString(), data: {} };
  for (const k of keys) {
    try {
      const r = await window.storage.get(SK(k));
      if (r) backup.data[k] = JSON.parse(r.value);
    } catch(e) {}
  }
  const blob = new Blob([JSON.stringify(backup, null, 2)], {type:'application/json'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'training-log-backup-' + new Date().toISOString().slice(0,10) + '.json';
  a.click();
  URL.revokeObjectURL(url);
  toast('Backup downloaded');
}

async function importData(event) {
  const file = event.target.files[0]; if (!file) return;
  const status = document.getElementById('backupStatus');
  try {
    const text = await file.text();
    const backup = JSON.parse(text);
    if (!backup.data) { toast('Invalid backup file'); return; }
    for (const [k, v] of Object.entries(backup.data)) {
      await window.storage.set(SK(k), JSON.stringify(v));
    }
    status.style.display = 'block';
    status.textContent = 'Backup restored — reloading...';
    setTimeout(() => window.location.reload(), 1200);
  } catch(e) {
    toast('Import failed — invalid file');
  }
  event.target.value = '';
}

