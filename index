function renderRunCalendar() {
  const el = document.getElementById('runCalendar'); if(!el) return;
  // Build 8-week calendar
  const today = new Date();
  const weeks = [];
  for (let w = 7; w >= 0; w--) {
    const days = [];
    for (let d = 0; d < 7; d++) {
      const date = new Date(today);
      date.setDate(today.getDate() - (w*7) - (6-d));
      days.push(date.toISOString().slice(0,10));
    }
    weeks.push(days);
  }

  // Collect all run dates with intensity
  const runsByDate = {};
  Object.values(runLogs||{}).forEach(runs => {
    runs.forEach(r => {
      if (!runsByDate[r.date]) runsByDate[r.date] = [];
      runsByDate[r.date].push(r.intensity || 'Moderate');
    });
  });

  const dayLabels = ['M','T','W','T','F','S','S'];
  const html = `
    <div style="margin-bottom:8px;display:flex;gap:4px;padding-left:28px">
      ${dayLabels.map(l=>`<div style="flex:1;text-align:center;font-size:9px;color:var(--t4);font-weight:600">${l}</div>`).join('')}
    </div>
    ${weeks.map((week, wi) => {
      const d = new Date(week[0] + 'T12:00:00');
      const mo = (d.getMonth()+1)+'/'+d.getDate();
      return `<div style="display:flex;gap:4px;margin-bottom:4px;align-items:center">
        <div style="font-size:9px;color:var(--t4);width:24px;flex-shrink:0">${mo}</div>
        ${week.map(dateStr => {
          const runs = runsByDate[dateStr] || [];
          const isToday = dateStr === todayStr();
          const col = runs.length ? (RUN_TYPES[runs[0]] || RUN_TYPES['Moderate']).color : 'transparent';
          const border = isToday ? '1px solid var(--t2)' : runs.length ? 'none' : '1px solid var(--b1)';
          const title = runs.length ? runs.join(', ') : '';
          return `<div style="flex:1;aspect-ratio:1;border-radius:4px;background:${runs.length?col+'22':'var(--s2)'};border:${border};display:flex;align-items:center;justify-content:center;cursor:${runs.length?'pointer':'default'}" title="${title}">
            ${runs.length ? `<div style="width:6px;height:6px;border-radius:50%;background:${col}"></div>` : ''}
          </div>`;
        }).join('')}
      </div>`;
    }).join('')}
    <div style="margin-top:10px;display:flex;flex-wrap:wrap;gap:8px">
      ${Object.entries(RUN_TYPES).filter(([k])=>k!=='—').map(([t,{color}])=>`
        <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:var(--t3)">
          <div style="width:8px;height:8px;border-radius:50%;background:${color}"></div>${t}
        </div>`).join('')}
    </div>`;
  el.innerHTML = html;
}

