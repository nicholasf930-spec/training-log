let progressPhotos = []; // [{id, date, dataUrl, weight, bf}]
let lightboxPhotoId = null;

async function loadPhotos() {
  try { const r=await window.storage.get(SK('photos')); progressPhotos=r?JSON.parse(r.value):[]; } catch(e){progressPhotos=[];}
}
async function savePhotos() { await save('photos', progressPhotos); }

function compressImage(dataUrl, maxDim=800, quality=0.75) {
  return new Promise(resolve => {
    const img = new Image();
    img.onload = () => {
      let {width:w, height:h} = img;
      const ratio = Math.min(maxDim/w, maxDim/h, 1);
      w = Math.round(w*ratio); h = Math.round(h*ratio);
      const canvas = document.createElement('canvas');
      canvas.width=w; canvas.height=h;
      canvas.getContext('2d').drawImage(img,0,0,w,h);
      resolve(canvas.toDataURL('image/jpeg', quality));
    };
    img.src = dataUrl;
  });
}

async function handleProgressPhoto(event) {
  const file = event.target.files[0]; if(!file) return;
  const status = document.getElementById('photoUploadStatus');
  status.style.display = 'block'; status.textContent = 'Compressing...';

  const reader = new FileReader();
  reader.onload = async e => {
    try {
      const compressed = await compressImage(e.target.result);
      const photoDateEl = document.getElementById('inPhotoDate');
      const photoDate = photoDateEl&&photoDateEl.value ? photoDateEl.value : todayStr();
      // Pull body stats for that specific date (or closest before it)
      const bodyForDate = [...bodyLog].filter(e=>e.date<=photoDate).sort((a,b)=>b.date.localeCompare(a.date))[0]||null;
      const weight = bodyForDate?.weight||null, bf = bodyForDate?.bf||null;
      const photo = { id:'ph_'+Date.now(), date:photoDate, dataUrl:compressed, weight, bf };
      progressPhotos.push(photo);
      await savePhotos();
      status.textContent = 'Photo saved';
      setTimeout(()=>{status.style.display='none';},2000);
      event.target.value=''; // reset so same file can be re-selected
      renderPhotoGrid();
    } catch(err) {
      status.textContent = 'Error saving photo';
    }
  };
  reader.readAsDataURL(file);
}

function renderPhotoGrid() {
  const grid = document.getElementById('photoGrid');
  if (!progressPhotos.length) {
    grid.innerHTML = '<div class="chart-empty" style="padding:20px 0">No photos yet — add your first one above</div>';
    return;
  }
  const sorted = [...progressPhotos].sort((a,b)=>b.date.localeCompare(a.date));
  grid.innerHTML = `<div class="photo-grid">${sorted.map(p=>{
    const d = new Date(p.date+'T12:00:00');
    const dateStr = d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
    const statsStr = [p.weight?p.weight+' lb':null, p.bf?p.bf+'% bf':null].filter(Boolean).join(' · ');
    return `<div class="photo-card" onclick="openLightbox('${p.id}')">
      <img src="${p.dataUrl}" alt="${dateStr}" loading="lazy">
      <div class="photo-card-meta">
        <div class="photo-card-date">${dateStr}</div>
        ${statsStr?`<div class="photo-card-stats">${statsStr}</div>`:''}
      </div>
    </div>`;
  }).join('')}</div>`;
}

function openLightbox(id) {
  const p = progressPhotos.find(x=>x.id===id); if(!p) return;
  lightboxPhotoId = id;
  const d = new Date(p.date+'T12:00:00');
  const dateStr = d.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
  const statsStr = [p.weight?p.weight+' lb':null, p.bf?p.bf+'% BF':null].filter(Boolean).join(' · ');
  document.getElementById('lightboxImg').src = p.dataUrl;
  document.getElementById('lightboxDate').textContent = dateStr;
  document.getElementById('lightboxStats').textContent = statsStr || 'No stats recorded';
  document.getElementById('lightbox').classList.add('show');
}
function closeLightboxBtn() { document.getElementById('lightbox').classList.remove('show'); lightboxPhotoId=null; }
function closeLightbox(e) { if(e.target===e.currentTarget) closeLightboxBtn(); }
function deletePhoto() {
  confirm2('Delete photo?','This cannot be undone.',async()=>{
    progressPhotos=progressPhotos.filter(p=>p.id!==lightboxPhotoId);
    await savePhotos();
    closeLightboxBtn();
    renderPhotoGrid();
    toast('Photo deleted');
  });
}


