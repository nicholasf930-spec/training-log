function renderExCard(ex, i, day) {
  const m = ex.muscle||'core', mc = MUSCLES[m]||MUSCLES.core;
  const log = logs[ex.id]||{};
  const sets = log.sets || ex.sets.map(s=>({w:s.w,r:s.r,done:false}));
  const sugg = suggest(ex);

  const muscleOpts = Object.entries(MUSCLES).map(([k,mc2])=>
    `<option value="${k}" ${m===k?'selected':''}>${mc2.label}</option>`).join('');

  const setRows = sets.map((set,si)=>{
    const s2 = sugg ? sugg.sets[si] : null;
    const vol = (+set.w||0)*(+set.r||0);
    const wVal = set.w!==undefined && set.w!=='' ? set.w : '';
    const rVal = set.r!==undefined && set.r!=='' ? set.r : '';
    const wPh  = s2 ? s2.w : (ex.sets[si]?.w||'');
    const rPh  = s2 ? s2.r : (ex.sets[si]?.r||'');
    return `<tr>
      <td class="set-num">${si+1}</td>
      <td><input class="set-field ${!wVal&&s2?'hint':''}" value="${esc(wVal)}" placeholder="${esc(wPh)}"
        onchange="setField('${ex.id}',${si},'w',this.value,'${day.id}')"></td>
      <td><input class="set-field ${!rVal&&s2?'hint':''}" value="${esc(rVal)}" placeholder="${esc(rPh)}"
        onchange="setField('${ex.id}',${si},'r',this.value,'${day.id}')"></td>
      <td class="vol-cell" data-volcell="${ex.id}-${si}">${vol>0?vol.toLocaleString():'—'}</td>
      <td><button class="check-btn ${set.done?'done':''}" id="cb-${ex.id}-${si}" onclick="toggleDone('${ex.id}',${si},'${day.id}')">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </button></td>
    </tr>`;
  }).join('');

  // Smart notes: pull last session note for this exercise
  const lastSession = (exHist[ex.id]||[]).slice(-1)[0];
  const lastNote = lastSession?.notes?.trim();
  const smartNoteHtml = lastNote ? `
    <div style="background:var(--s3);border:1px solid var(--b1);border-radius:6px;padding:8px 10px;margin-bottom:10px;display:flex;gap:8px;align-items:flex-start">
      <span style="font-size:9px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--t4);white-space:nowrap;padding-top:1px">Wk ${lastSession.week}</span>
      <span style="font-size:12px;color:var(--t3);font-style:italic;line-height:1.5">"${esc(lastNote)}"</span>
    </div>` : '';

