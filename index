// ── EXERCISE PROGRESS ──────────────────────────────────
function populateExSelector() {
  const sel = document.getElementById('exSelector');
  const current = sel.value;

  // Collect all exercises across all days
  const allEx = {};
  plan.days.forEach(d => d.exercises.forEach(ex => {
    if (!allEx[ex.id]) allEx[ex.id] = { name: ex.name, muscle: ex.muscle };
  }));
  // Also include any in history that no longer exist in plan
  Object.keys(exHist).forEach(id => {
    if (!allEx[id] && exHist[id].length > 0) {
      allEx[id] = { name: exHist[id][0].exName || id, muscle: 'core' };
    }
  });
  // Only include those with history
  const withHist = Object.entries(allEx).filter(([id]) => (exHist[id]||[]).length > 0);

  // Group by day name for optgroups
  const byDay = {};
  plan.days.forEach(d => {
    d.exercises.forEach(ex => {
      if (!byDay[d.name]) byDay[d.name] = [];
      if (withHist.find(([id])=>id===ex.id)) byDay[d.name].push({id:ex.id, name:ex.name});
    });
  });

  let html = '<option value="">Select an exercise...</option>';
  let hasAny = false;
  Object.entries(byDay).forEach(([dayName, exes]) => {
    if (!exes.length) return;
    hasAny = true;
    html += `<optgroup label="${esc(dayName)}">`;
    exes.forEach(e => html += `<option value="${e.id}" ${e.id===current?'selected':''}>${esc(e.name)}</option>`);
    html += '</optgroup>';
  });

  if (!hasAny) html += '<option value="" disabled>Complete a week to see progress</option>';
  sel.innerHTML = html;

  if (current && sel.value === current) renderExProgress();
  else document.getElementById('exProgressArea').innerHTML = '<div class="chart-empty" style="padding:30px 0">Select an exercise to view its progress</div>';
}

function renderExProgress() {
  const exId = document.getElementById('exSelector').value;
  const area = document.getElementById('exProgressArea');
  if (!exId) { area.innerHTML = '<div class="chart-empty" style="padding:30px 0">Select an exercise to view its progress</div>'; return; }

  const hist = exHist[exId] || [];
  if (!hist.length) { area.innerHTML = '<div class="chart-empty" style="padding:30px 0">No history yet — complete a week to log data</div>'; return; }

  const sorted = [...hist].sort((a,b)=>a.week-b.week);

  // Summary stats
  const vols = sorted.map(s=>s.vol||totalVol(s.sets));
  const maxVol = Math.max(...vols), latestVol = vols[vols.length-1];
  const firstVol = vols[0];
  const totalGain = latestVol - firstVol;
  const avgSet0W = sorted.map(s=>s.sets[0]?.w||0);
  const maxW = Math.max(...avgSet0W);

  // Build labels as "Wk N"
  const labels = sorted.map(s=>'Wk '+s.week);

  // Volume chart
  const volChartDiv = document.createElement('div');
  volChartDiv.className = 'chart-card';

  const volLegendHtml = `<div class="chart-legend-row">
    <div class="chart-legend-item"><div class="chart-legend-pip" style="background:#4a9e62"></div>Volume (lb×reps)</div>
  </div>`;

  area.innerHTML = `
    <div class="stat-summary-row">
      <div class="stat-summary-box">
        <div class="stat-summary-label">Latest Vol</div>
        <div class="stat-summary-val">${latestVol.toLocaleString()}<span class="stat-summary-unit"></span></div>
      </div>
      <div class="stat-summary-box">
        <div class="stat-summary-label">Peak Vol</div>
        <div class="stat-summary-val">${maxVol.toLocaleString()}</div>
      </div>
      <div class="stat-summary-box">
        <div class="stat-summary-label">Total Gain</div>
        <div class="stat-summary-val" style="color:${totalGain>=0?'var(--up)':'var(--danger)'}">${totalGain>=0?'+':''}${totalGain.toLocaleString()}</div>
      </div>
    </div>

    <div class="section-head">Volume per Session</div>
    <div class="chart-card" id="exVolChart">
      ${volLegendHtml}
    </div>

    <div class="section-head">Top Set Weight per Session</div>
    <div class="chart-card" id="exWtChart"></div>

    <div class="section-head">Session Log</div>
    <div id="exSessionLog"></div>`;

  // Volume chart
  buildChart(document.getElementById('exVolChart'), [{values:vols, color:'#4a9e62'}], {labels, height:140, padL:52});

  // Weight chart (top set weight)
  buildChart(document.getElementById('exWtChart'), [{values:avgSet0W, color:'#f0f0f4'}], {labels, height:140, padL:44});

  // Session log
  const logEl = document.getElementById('exSessionLog');
  const sessionsHtml = sorted.reverse().map(s => {
    const vol = s.vol || totalVol(s.sets);
    const chips = (s.sets||[]).map(set =>
      `<div class="ex-log-set-chip">${set.w>0?set.w+' × ':''}<span style="color:var(--t3)">${set.r}</span></div>`
    ).join('');
    return `<div class="ex-log-session">
      <div class="ex-log-session-head">
        <span class="ex-log-week">Week ${s.week}</span>
        <span class="ex-log-vol">${vol.toLocaleString()} vol</span>
      </div>
      <div class="ex-log-sets">${chips}</div>
      ${s.notes ? `<div class="ex-log-notes">"${esc(s.notes)}"</div>` : ''}
    </div>`;
  }).join('');
  logEl.innerHTML = sessionsHtml || '<div class="chart-empty">No sessions logged</div>';
}

// Partial nutrition update (meters only — no full re-render, preserves focus)
function updateNutritionMeters() {
  const lastBody=[...bodyLog].sort((a,b)=>b.date.localeCompare(a.date))[0]||null;
  const weight=+(lastBody?.weight)||+(profile.weight)||0;
  const tdee=calcTDEE({...profile,weight});
  const calGoal=calcCalGoal(profile,tdee);
  const protGoal=weight>0?Math.round(weight):null;
  const today=getViewingDate();
  const meals=mealLogs[today]||[];
  // Update section label
  const dl=document.getElementById('nutritionDateLabel'); if(dl){const isT=today===todayStr(); const d=new Date(today+'T12:00:00'); dl.textContent=isT?'Today':d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});}
  const totCal=meals.reduce((a,m)=>a+(+m.cal||0),0);
  const totP=meals.reduce((a,m)=>a+(+(m.protein||m.p)||0),0);
  // Apply training-nutrition sync (adjusts effective calorie goal for today)
  const effectiveCalGoal = typeof renderSyncBanner === 'function' ? renderSyncBanner(calGoal) : calGoal;
  const calPct=effectiveCalGoal?Math.min(totCal/effectiveCalGoal,1):0;
  const rem=effectiveCalGoal?effectiveCalGoal-totCal:null;
  const sb=(id,v)=>{const e=document.getElementById(id);if(e)e.textContent=v;};
  const ss=(id,v)=>{const e=document.getElementById(id);if(e)e.style.width=v;};
  sb('mCalVal',totCal.toLocaleString());
  sb('mCalGoal',effectiveCalGoal?`/ ${effectiveCalGoal.toLocaleString()} goal`:'/ set goal below');
  ss('mCalBar',(calPct*100)+'%');
  const calBar=document.getElementById('mCalBar');
  if(calBar) calBar.style.background=calPct>1?'#b85868':'#f0f0f4';
  sb('mCalSub',rem!=null?(rem>=0?`${rem.toLocaleString()} remaining`:`${Math.abs(rem).toLocaleString()} over budget`):'Log meals to begin');
  const protPct=protGoal?Math.min(totP/protGoal,1):0;
  sb('mProtVal',totP); sb('mProtGoal',protGoal?`/ ${protGoal}g target`:'/ log weight below');
  ss('mProtBar',(protPct*100)+'%');
  const protBar=document.getElementById('mProtBar');
  if(protBar) protBar.style.background=protPct>=1?'#4a9e62':'#3a9e98';
  sb('mProtSub',protGoal&&totP<protGoal?`${protGoal-totP}g to go`:(protGoal&&totP>=protGoal?'Target reached':'1g per lb bodyweight'));
  sb('sbWeight',weight?weight+' lb':'—'); sb('sbBF',(lastBody?.bf)?lastBody.bf+'%':'—'); sb('sbTDEE',tdee?tdee+' kcal':'—');
  // Goal summary now rendered in Goals panel
}

