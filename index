}

// Muscles shown in volume sidebar (excludes aliases)
const VOL_MUSCLES = ['chest','back','front_delt','side_delt','rear_delt',
  'bicep','tricep','forearm','quad','hamstring','glute','calf','core'];

// Run type colors
const RUN_TYPES = {
  Easy:     {color:'#42bfb8'}, Moderate: {color:'#6aa0e0'},
  Tempo:    {color:'#e8954a'}, Interval: {color:'#e07080'},
  'Long Run':{color:'#9585e8'}, Sprint:   {color:'#f2c44a'},
  Recovery: {color:'#62c87a'}, '—':      {color:'#44445a'},
};

function renderVolSidebar() {
  const inner = document.getElementById('volSidebarInner'); if(!inner) return;
  const volByMuscle = {};
  plan.days.forEach(d=>d.exercises.forEach(ex=>{
    const m=ex.muscle||'core';
    volByMuscle[m]=(volByMuscle[m]||0)+ex.sets.length;
  }));

  // Run volume this week
  const runVolByType = {};
  Object.values(runLogs||{}).forEach(runs=>{
    // last 7 days
    const cutoff=new Date(); cutoff.setDate(cutoff.getDate()-7);
    runs.filter(r=>new Date(r.date+'T12:00:00')>=cutoff).forEach(r=>{
      const t=r.intensity||'—';
      runVolByType[t]=(runVolByType[t]||0)+(+r.distance||0);
    });
  });

  const muscleHtml = VOL_MUSCLES.map(k=>{
    const mc=MUSCLES[k]; if(!mc) return '';
    const v=volByMuscle[k]||0;
    const maxV=Math.max(...VOL_MUSCLES.map(m=>volByMuscle[m]||0),1);
    return `<div class="vol-item">
      <div class="vol-item-top"><span class="vol-item-name" style="color:${mc.color}">${mc.label}</span><span class="vol-item-num">${v}</span></div>
      <div class="vol-track"><div class="vol-fill" style="width:${Math.round(v/maxV*100)}%;background:${mc.color};opacity:0.8"></div></div>
    </div>`;
  }).join('');

  const runEntries = Object.entries(runVolByType);
  const runHtml = runEntries.length ? runEntries.map(([t,mi])=>{
    const col=(RUN_TYPES[t]||RUN_TYPES['—']).color;
    const maxMi=Math.max(...runEntries.map(([,m])=>m),1);
    return `<div class="vol-item">
      <div class="vol-item-top"><span class="vol-item-name" style="color:${col}">${t}</span><span class="vol-item-num">${mi.toFixed(1)}mi</span></div>
      <div class="vol-track"><div class="vol-fill" style="width:${Math.round(mi/maxMi*100)}%;background:${col};opacity:0.8"></div></div>
    </div>`;
  }).join('') : '<div style="font-size:11px;color:var(--t4);padding:4px 0">No runs this week</div>';

  inner.innerHTML=`
    <div class="vol-sidebar-title">Weekly Sets</div>
    ${muscleHtml}
    <div class="vol-sidebar-title" style="margin-top:14px;padding-top:10px;border-top:1px solid var(--b1)">Runs (7 days)</div>
    ${runHtml}`;
}

