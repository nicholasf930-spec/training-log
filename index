const esc = s => String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
const todayStr = () => new Date().toISOString().slice(0,10);
function getViewingDate() { try { const el=document.getElementById('nutritionDate'); return (el&&el.value)?el.value:todayStr(); } catch(e){return todayStr();} }
function setNutritionDateToday() { const el=document.getElementById('nutritionDate'); if(el){el.value=todayStr(); renderNutrition();} }
const totalVol = sets => sets.reduce((a,s)=>a+((+s.w||0)*(+s.r||0)),0);
function toast(msg) {
  const t=document.getElementById('toastEl');
  t.textContent=msg; t.classList.add('show');
  clearTimeout(t._t); t._t=setTimeout(()=>t.classList.remove('show'),2200);
}

// ═══════════════════════════════════════════════════════
// PROGRESSION ENGINE
// ═══════════════════════════════════════════════════════
function suggest(ex) {
  const hist = (exHist[ex.id]||[]).slice(-1)[0];
  if (!hist || !hist.sets || !hist.sets.length) return null;
  const min = ex.rMin || 6, max = ex.rMax || 12;
  const prevSets = hist.sets;
  const prevVol = totalVol(prevSets);

  // Build suggestions guaranteed to beat prevVol
  let suggested = prevSets.map(s => {
    const w = +s.w||0, r = +s.r||0;
    if (w === 0) return {w:0, r:Math.min(r+1, max)};
    if (r < max) return {w, r:r+1};
    // At rep ceiling — bump weight, drop to min reps
    const bump = w >= 200 ? 10 : w >= 100 ? 5 : 2.5;
    return {w: w+bump, r: min};
  });

  // Verify volume actually increased; if not, force it
  let newVol = totalVol(suggested);
  if (newVol <= prevVol && suggested[0].w > 0) {
    // Extra nudge: add another rep to first set
    suggested = suggested.map((s,i) => i===0&&s.r<max ? {...s, r:s.r+1} : s);
    newVol = totalVol(suggested);
  }

  const pct = prevVol > 0 ? Math.round((newVol-prevVol)/prevVol*100) : 0;
  return { sets: suggested, prevVol, newVol, pct };
}

// ═══════════════════════════════════════════════════════
// PANEL SWITCHING
// ═══════════════════════════════════════════════════════
function switchPanel(id) {
  // Fade out current panel briefly before switching
  const current = document.querySelector('.panel.active');
  document.querySelectorAll('.tab-item').forEach(t=>t.classList.toggle('active', t.id==='tab-'+id));
  if (current && current.id !== 'panel-'+id) {
    current.classList.add('entering');
    setTimeout(() => {
      document.querySelectorAll('.panel').forEach(p=>p.classList.toggle('active', p.id==='panel-'+id));
      document.querySelectorAll('.panel').forEach(p=>p.classList.remove('entering'));
      runPanelInit(id);
    }, 80);
  } else {
    document.querySelectorAll('.panel').forEach(p=>p.classList.toggle('active', p.id==='panel-'+id));
    runPanelInit(id);
  }
}
function runPanelInit(id) {
  if (id==='nutrition') renderNutrition();
  if (id==='goals') renderGoalsPanel();
  if (id==='runs') renderRunsPanel();
  if (id==='progress') renderProgress();
}

