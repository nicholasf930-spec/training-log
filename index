function renderGoalsPanel() {
  // Populate inputs from profile
  const age = document.getElementById('inAge');
  const ht = document.getElementById('inHeight');
  const sx = document.getElementById('inSex');
  const gr = document.getElementById('goalRate');
  const ac = document.getElementById('activitySel');
  if (age && profile.age) age.value = profile.age;
  if (ht && profile.height) ht.value = profile.height;
  if (sx && profile.sex) sx.value = profile.sex;
  if (gr && profile.goalRate) gr.value = profile.goalRate;
  if (ac && profile.activity) ac.value = profile.activity;

  // Set goal mode tabs
  ['lose','maintain','gain'].forEach(m => {
    const el = document.getElementById('gt-'+m);
    if (el) el.classList.toggle('active', (profile.goalMode||'lose') === m);
  });

  // Show/hide rate based on mode
  const rw = document.getElementById('goalRateWrap');
  if (rw) rw.style.display = (profile.goalMode==='maintain') ? 'none' : 'grid';

  renderGoalResult();
  renderPhaseCard();
  renderProjections();
}

function renderGoalResult() {
  const lastBody = [...bodyLog].sort((a,b)=>b.date.localeCompare(a.date))[0]||null;
  const weight = +(lastBody?.weight)||+(profile.weight)||0;
  const tdee = calcTDEE({...profile, weight});
  const calGoal = calcCalGoal(profile, tdee);

  const resEl = document.getElementById('goalCalResult');
  const bkEl = document.getElementById('goalCalBreakdown');
  if (!resEl) return;

  if (!tdee || !calGoal) {
    resEl.textContent = '—';
    if (bkEl) bkEl.textContent = 'Complete your profile above to calculate';
    return;
  }

  resEl.textContent = calGoal.toLocaleString();

  const mode = profile.goalMode || 'lose';
  const rate = +profile.goalRate || 0.5;
  const delta = calGoal - tdee;
  const modeStr = mode==='lose' ? `Losing ~${rate} lb/week` : mode==='gain' ? `Gaining ~${rate} lb/week` : 'Maintaining weight';
  const deltaStr = delta === 0 ? 'At maintenance' : (delta < 0 ? `${Math.abs(delta).toLocaleString()} kcal deficit` : `${delta.toLocaleString()} kcal surplus`);
  if (bkEl) bkEl.innerHTML = `TDEE: <strong style="color:var(--t2)">${tdee.toLocaleString()} kcal</strong><br>${modeStr} &nbsp;·&nbsp; ${deltaStr}`;
}

