          ${lastSession&&lastSession.sets&&lastSession.sets.length?`<span style="font-size:10px;color:var(--t4);margin-left:2px">&nbsp;Last: ${lastSession.sets.map(s=>(s.w&&s.w>0?s.w+'×':'')+s.r).join(', ')}</span>`:''}
        </div>
