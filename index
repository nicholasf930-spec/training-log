        <button class="btn sm" onclick="openSwapMenu('${day.id}','${ex.id}')">${_tempSwaps[ex.id]?'Change':'Swap'}</button>
        ${_tempSwaps[ex.id]?`<button class="btn sm" onclick="clearTempSwap('${ex.id}')" style="color:var(--warn)">Revert</button>`:''}
        <button class="btn sm danger" onclick="removeEx('${ex.id}','${day.id}')">Remove</button>
