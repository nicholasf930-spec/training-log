async function handlePhoto(event) {
  const file=event.target.files[0]; if(!file) return;
  const reader=new FileReader();
  reader.onload=async e=>{
    const dataUrl=e.target.result;
    const prev=document.getElementById('photoPreview');
    if(prev){prev.src=dataUrl;prev.style.display='block';}
    const box=document.getElementById('aiBox');
    if(box){box.style.display='block';box.textContent='Analyzing...';}
    try {
      const base64=dataUrl.split(',')[1];
      const resp=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
        model:'claude-sonnet-4-20250514',max_tokens:500,
        messages:[{role:'user',content:[
          {type:'image',source:{type:'base64',media_type:file.type,data:base64}},
          {type:'text',text:'Analyze this meal photo. Respond ONLY with valid JSON (no markdown): {"name":"description","calories":0,"protein":0,"carbs":0,"fat":0,"confidence":"low|medium|high"}'}
        ]}]
      })});
      const data=await resp.json();
      const text=data.content?.find(b=>b.type==='text')?.text||'{}';
      const p=JSON.parse(text.replace(/```json|```/g,'').trim());
      if(box) box.innerHTML=`<strong>${esc(p.name||'Meal')}</strong> &mdash; ~${p.calories||0} kcal &middot; ${p.protein||0}g P &middot; ${p.carbs||0}g C &middot; ${p.fat||0}g F<br><small style="color:var(--t4)">Confidence: ${p.confidence||'medium'} — verify before adding</small>`;
      const set=(id,v)=>{const el=document.getElementById(id);if(el)el.value=v;};
      set('mName',p.name||'');set('mCal',p.calories||'');set('mPro',p.protein||'');
    } catch(err) {
      if(box) box.textContent='Could not analyze — fill in manually.';
    }
  };
  reader.readAsDataURL(file);
}

function startBC() {
  const vid=document.getElementById('bcVideo'); if(!vid) return;
  vid.style.display='block';
  if(typeof Quagga==='undefined'){toast('Barcode scanner unavailable');return;}
  Quagga.init({inputStream:{type:'LiveStream',target:vid,constraints:{facingMode:'environment'}},decoder:{readers:['ean_reader','upc_reader','code_128_reader']}},err=>{
    if(err){toast('Camera unavailable');return;}
    Quagga.start(); bcActive2=true;
  });
  Quagga.onDetected(r=>{const code=r.codeResult.code;stopBC();lookupBC(code);});
}
function stopBC(){if(bcActive2&&typeof Quagga!=='undefined'){try{Quagga.stop();}catch(e){}bcActive2=false;}const v=document.getElementById('bcVideo');if(v)v.style.display='none';}
async function lookupBC(code) {
  if(!code){toast('No barcode');return;}
  const res=document.getElementById('bcResult');
  if(res){res.style.display='block';res.textContent=`Looking up ${code}...`;}
  try {
    const r=await fetch(`https://world.openfoodfacts.org/api/v0/product/${code}.json`);
    const data=await r.json();
    if(data.status!==1){if(res)res.textContent='Product not found';return;}
    const p=data.product,n=p.nutriments;
    const name=p.product_name||p.brands||'Product';
    const cal=Math.round(n['energy-kcal_serving']||n['energy-kcal_100g']||0);
    const prot=Math.round(n.proteins_serving||n.proteins_100g||0);
    const carb=Math.round(n.carbohydrates_serving||n.carbohydrates_100g||0);
    const fat=Math.round(n.fat_serving||n.fat_100g||0);
    if(res) res.innerHTML=`<strong>${esc(name)}</strong><br>${cal} kcal · ${prot}g P · ${carb}g C · ${fat}g F`;
    const set=(id,v)=>{const el=document.getElementById(id);if(el)el.value=v;};
    set('mName',name);set('mCal',cal);set('mPro',prot);
  } catch(e){if(res)res.textContent='Lookup failed';}
}

