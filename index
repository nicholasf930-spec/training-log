function renderProjections() {
  const card = document.getElementById('projectionsCard');
  if (!card) return;
  const lastBody = [...bodyLog].sort((a,b)=>b.date.localeCompare(a.date))[0]||null;
  const weight = lastBody?.weight || profile.weight || 0;
  const bf = lastBody?.bf || profile.bf || 0;
  const tdee = calcTDEE({...profile, weight});
  const calGoal = calcCalGoal(profile, tdee);

  if (!weight || !tdee || !calGoal) {
    card.innerHTML = '<div class="chart-empty">Log your weight and complete your profile to see projections</div>';
    return;
  }

  const dailyDelta = calGoal - tdee; // negative = deficit
  const lbsPerWeek = dailyDelta * 7 / 3500;

  const rows = [4, 8, 12].map(weeks => {
    const projW = Math.max(0, weight + lbsPerWeek * weeks);
    // Estimate BF%: assume lean mass stays roughly constant, fat changes
    let projBF = bf;
    if (bf && weight) {
      const leanMass = weight * (1 - bf/100);
      const projFatMass = weight * (bf/100) + (lbsPerWeek * weeks);
      const projTotalW = leanMass + projFatMass;
      projBF = Math.max(1, Math.min(50, (projFatMass/projTotalW)*100));
    }
    const col = lbsPerWeek < -0.05 ? 'var(--danger)' : lbsPerWeek > 0.05 ? 'var(--up)' : 'var(--t3)';
    return `<div class="stat-box" style="text-align:center">
      <div class="stat-box-label">${weeks} Weeks</div>
      <div class="stat-box-val" style="color:${col}">${projW.toFixed(1)}<span class="stat-box-unit"> lb</span></div>
      ${projBF?`<div style="font-size:10px;color:var(--t3);margin-top:2px">${projBF.toFixed(1)}% BF</div>`:''}
    </div>`;
  });

  const direction = lbsPerWeek < -0.05 ? 'losing' : lbsPerWeek > 0.05 ? 'gaining' : 'maintaining';
  const rateStr = Math.abs(lbsPerWeek).toFixed(2);
  card.innerHTML = `
    <div style="font-size:11px;color:var(--t3);margin-bottom:12px;line-height:1.6">
      At your current ${calGoal.toLocaleString()} kcal/day target, you're <strong style="color:var(--t1)">${direction} ~${rateStr} lb/week</strong>.
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px">
      ${rows.join('')}
    </div>
    ${phase?`<div style="margin-top:10px;padding-top:10px;border-top:1px solid var(--b1);font-size:11px;color:var(--t3)">
      Phase goal: ${phase.startWeight} → ${phase.goalWeight} lb in ${phase.durationWeeks} weeks requires ~${Math.abs((phase.goalWeight-phase.startWeight)*3500/(phase.durationWeeks*7)).toFixed(0)} kcal/day deficit${(phase.goalWeight<phase.startWeight)?'':' surplus'}.
    </div>`:''}`;
}

// Override renderBodyCharts to include phase goal line
const _origRenderBodyCharts = renderBodyCharts;
function renderBodyCharts() {
  const entries = [...bodyLog].sort((a,b)=>a.date.localeCompare(b.date));

  if (entries.length < 1) {
    ['chartWeight','chartBF','bodyHistTable'].forEach(id=>{
      const el=document.getElementById(id);
      if(el) el.innerHTML='<div class="chart-empty">No body data yet — log your weight daily</div>';
    });
    return;
  }

  const labels = entries.map(e=>{
    const d=new Date(e.date+'T12:00:00');
    return (d.getMonth()+1)+'/'+d.getDate();
  });

  // Build goal line dataset if phase active
  let goalDataset = null;
  if (phase) {
    const phaseStart = new Date(phase.startDate+'T12:00:00');
    const goalVals = entries.map(e=>{
      const d=new Date(e.date+'T12:00:00');
      const weeksIn=Math.max(0,(d-phaseStart)/(1000*60*60*24*7));
      if(weeksIn<0||weeksIn>phase.durationWeeks) return null;
      return phase.startWeight+(phase.goalWeight-phase.startWeight)*(weeksIn/phase.durationWeeks);
    });
    if (goalVals.some(v=>v!==null)) {
      goalDataset = { values: goalVals, color: '#c8853a', dash: true, label: 'Goal' };
    }
  }

  const wVals = entries.map(e=>e.weight);
  const datasets = [{values:wVals, color:'#f0f0f4', label:'Weight'}];
  if (goalDataset) datasets.push(goalDataset);

  if (wVals.some(v=>v)) {
    buildChart(document.getElementById('chartWeight'), datasets, {labels, height:140, padL:44});
  } else {
    document.getElementById('chartWeight').innerHTML='<div class="chart-empty">No weight data yet</div>';
  }

  const bfVals=entries.map(e=>e.bf);
  if(bfVals.some(v=>v)){
    buildChart(document.getElementById('chartBF'),[{values:bfVals,color:'#b85868'}],{labels,height:130,padL:36});
  } else {
    document.getElementById('chartBF').innerHTML='<div class="chart-empty">No body fat data yet</div>';
  }

  // History table with delete button and lean mass column
  const sorted=[...entries].reverse();
  let tableHtml=`<table class="data-table">
    <thead><tr><th>Date</th><th>Weight</th><th>BF%</th><th>Lean</th><th>Δ</th><th></th></tr></thead><tbody>`;
  sorted.forEach((e,idx)=>{
    const prev=sorted[idx+1];
    let delta='';
    if(prev&&e.weight&&prev.weight){
      const diff=(e.weight-prev.weight).toFixed(1);
      // No color judgment — change is neutral info
      delta=`<span style="color:var(--t3)">${diff>0?'+':''}${diff}</span>`;
    }
    const lean=e.weight&&e.bf?((e.weight*(1-e.bf/100)).toFixed(1)+' lb'):'—';
    const d=new Date(e.date+'T12:00:00');
    const dateStr=d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'2-digit'});
    tableHtml+=`<tr>
      <td style="color:var(--t2)">${dateStr}</td>
      <td>${e.weight?e.weight+' lb':'—'}</td>
      <td>${e.bf?e.bf+'%':'—'}</td>
      <td style="color:var(--t3)">${lean}</td>
      <td>${delta||'—'}</td>
      <td><button onclick="deleteBodyEntry('${e.date}')" style="background:transparent;border:none;color:var(--t4);cursor:pointer;font-size:13px;padding:2px 4px" title="Delete">&#x2715;</button></td>
    </tr>`;
  });
  tableHtml+='</tbody></table>';
  document.getElementById('bodyHistTable').innerHTML=tableHtml;
}

function deleteBodyEntry(date) {
  confirm2('Delete entry?', `Remove the body log for ${date}?`, async () => {
    bodyLog = bodyLog.filter(e=>e.date!==date);
    await save('bodylog',bodyLog);
    renderBodyCharts();
    toast('Entry deleted');
  });
}

// Update buildChart to support dashed lines
const _origBuildChart = buildChart;
function buildChart(container, datasets, opts={}) {
  const W=600, H=opts.height||120, padL=opts.padL||40, padR=20, padT=12, padB=28;
  const innerW=W-padL-padR, innerH=H-padT-padB;

  const allVals=datasets.flatMap(d=>d.values.filter(v=>v!=null));
  if(!allVals.length){container.innerHTML='<div class="chart-empty">Not enough data yet</div>';return;}

  const mn=Math.min(...allVals), mx=Math.max(...allVals);
  const range=mx-mn||1;
  const yMin=mn-range*0.12, yMax=mx+range*0.12;
  const labels=opts.labels||datasets[0].values.map((_,i)=>String(i+1));

  const xPos=(i,n)=>padL+(n>1?(i/(n-1))*innerW:innerW/2);
  const yPos=v=>padT+innerH-((v-yMin)/(yMax-yMin))*innerH;

  let svg=`<svg class="chart-svg" viewBox="0 0 ${W} ${H}" preserveAspectRatio="none">`;

  // Y grid
  for(let g=0;g<=3;g++){
    const y=padT+(g/3)*innerH;
    const val=yMax-(g/3)*(yMax-yMin);
    svg+=`<line x1="${padL}" y1="${y.toFixed(1)}" x2="${W-padR}" y2="${y.toFixed(1)}" stroke="var(--b1)" stroke-width="1"/>`;
    svg+=`<text x="${padL-4}" y="${(y+3).toFixed(1)}" font-size="9" fill="var(--t4)" font-family="Inter" text-anchor="end">${Math.round(val)}</text>`;
  }

  // X labels (up to 8)
  const n=labels.length, step=Math.max(1,Math.ceil(n/8));
  for(let i=0;i<n;i+=step){
    const x=xPos(i,n);
    svg+=`<text x="${x.toFixed(1)}" y="${H-4}" font-size="9" fill="var(--t4)" font-family="Inter" text-anchor="middle">${esc(String(labels[i]))}</text>`;
  }

  // Legend if multiple datasets
  if(datasets.length>1&&datasets.some(d=>d.label)){
    let lx=padL;
    datasets.forEach(ds=>{
      if(!ds.label) return;
      svg+=`<line x1="${lx}" y1="${padT-2}" x2="${lx+14}" y2="${padT-2}" stroke="${ds.color}" stroke-width="1.5" ${ds.dash?'stroke-dasharray="4,3"':''}/>`;
      svg+=`<text x="${lx+18}" y="${padT+1}" font-size="9" fill="var(--t3)" font-family="Inter">${esc(ds.label)}</text>`;
      lx+=60;
    });
  }

  datasets.forEach(ds=>{
    const pts=ds.values.map((v,i)=>v!=null?[xPos(i,n),yPos(v)]:null);
    const valid=pts.filter(Boolean);
    if(!valid.length) return;

    if(valid.length>1){
      // Build path with gaps for null values
      let d='';
      pts.forEach((p,i)=>{
        if(!p) return;
        const prev=pts.slice(0,i).reverse().find(Boolean);
        d+=(d===''||!prev)?`M${p[0].toFixed(1)},${p[1].toFixed(1)} `:`L${p[0].toFixed(1)},${p[1].toFixed(1)} `;
      });
      svg+=`<path d="${d.trim()}" fill="none" stroke="${ds.color}" stroke-width="${ds.dash?1.2:1.8}" stroke-linejoin="round" stroke-linecap="round" ${ds.dash?'stroke-dasharray="5,4"':''}/>`;

      // Gradient area fill (only for solid lines)
      if(!ds.dash){
        const gid='g'+Math.random().toString(36).slice(2,8);
        svg+=`<defs><linearGradient id="${gid}" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="${ds.color}" stop-opacity="0.12"/>
          <stop offset="100%" stop-color="${ds.color}" stop-opacity="0"/>
        </linearGradient></defs>`;
        const firstV=valid[0], lastV=valid[valid.length-1];
        const bottom=padT+innerH;
        let area=`M${firstV[0].toFixed(1)},${bottom.toFixed(1)} `;
        pts.forEach(p=>{if(p)area+=`L${p[0].toFixed(1)},${p[1].toFixed(1)} `;});
        area+=`L${lastV[0].toFixed(1)},${bottom.toFixed(1)} Z`;
        svg+=`<path d="${area}" fill="url(#${gid})"/>`;
      }
    }

    // Dots (only on solid, non-dashed lines)
    if(!ds.dash){
      pts.forEach(p=>{
        if(!p) return;
        svg+=`<circle cx="${p[0].toFixed(1)}" cy="${p[1].toFixed(1)}" r="2.5" fill="${ds.color}" stroke="var(--s1)" stroke-width="1.5"/>`;
      });
      // Last value label
      const last=valid[valid.length-1];
      const lastVal=ds.values.filter(v=>v!=null).slice(-1)[0];
      svg+=`<text x="${(last[0]+5).toFixed(1)}" y="${(last[1]-4).toFixed(1)}" font-size="10" fill="${ds.color}" font-family="Inter" font-weight="600">${typeof lastVal==='number'?lastVal.toFixed(1):lastVal}</text>`;
    }
  });

  svg+='</svg>';
  container.innerHTML=svg;
}

