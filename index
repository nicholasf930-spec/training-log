function getTrainingBonus() {
  const dowMap=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const todayDow=dowMap[new Date().getDay()];
  const todayDay=plan?.days?.find(d=>d.dow===todayDow);
  if(!todayDay) return null;
  let extraBurn=0;
  const hasLifts=todayDay.exercises&&todayDay.exercises.length>0;
  const hasRun=todayDay.runEnabled;
  if(hasLifts){ const sets=todayDay.exercises.reduce((a,ex)=>a+ex.sets.length,0); extraBurn+=sets*6; }
  if(hasRun){
    const rt=todayDay.runTarget||{};
    extraBurn+= +rt.distance?Math.round(+rt.distance*100): +rt.duration?Math.round(+rt.duration*10):80;
  }
  if(!extraBurn) return null;
  const type=hasRun&&hasLifts?'Hybrid day':hasRun?'Run day':'Training day';
  return {extraBurn,type};
}

