let _searchTimer = null;
function handleFoodSearch(val) {
  clearTimeout(_searchTimer);
  const status = document.getElementById('searchStatus');
  const results = document.getElementById('foodResults');
  if (!val.trim()) {
    if(status) status.textContent='Type to search Open Food Facts database';
    if(results) results.innerHTML=''; return;
  }
  if(status) { status.textContent='Searching...'; status.closest('.food-result-item').style.opacity='1'; }
  _searchTimer = setTimeout(async () => {
    const foods = await searchFoods(val);
    // Also search custom foods
    const custom = customFoods.filter(f=>f.name.toLowerCase().includes(val.toLowerCase()));
    const all = [...custom.map(f=>({...f,isCustom:true})), ...foods];
    if (!all.length) {
      if(results) results.innerHTML='<div class="food-search-empty">No results found</div>';
      if(status) { status.textContent='No results — try different terms or create a custom food'; status.closest('.food-result-item').style.opacity='0.5';}
      return;
    }
    if(status) status.closest('.food-result-item').style.display='none';
    results.innerHTML = all.slice(0,15).map(f=>`
      <div class="food-result-item" onclick="selectFood('${esc(f.name.replace(/'/g,"\\'"))}',${f.cal},${f.protein})">
        <div class="food-result-name">${esc(f.name)}${f.isCustom?' <span style="font-size:9px;color:var(--t4);font-weight:600;letter-spacing:0.1em">CUSTOM</span>':''}</div>
        <div class="food-result-cals">${f.cal} kcal · ${f.protein}g P</div>
      </div>`).join('');
  }, 400);
}

