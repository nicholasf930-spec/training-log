function confirmMeal() {
  const name=document.getElementById('mName')?.value?.trim();
  const cal=+document.getElementById('mCal')?.value||0;
  const protein=+document.getElementById('mPro')?.value||0;
  const dateVal=document.getElementById('mDate')?.value||todayStr();
