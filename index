function toggleCard(id) {
  const c=document.getElementById('ec-'+id); if(!c) return;
  const open=!c.classList.contains('open');
  c.classList.toggle('open',open);
  if(!logs[id]) logs[id]={};
  logs[id].open=open; save('logs',logs);
}

function ensureLog(exId, dayId) {
  if (!logs[exId] || !Array.isArray(logs[exId].sets)) {
    const day=plan.days.find(d=>d.id===dayId);
    const ex=day?.exercises.find(e=>e.id===exId);
    logs[exId]={sets:ex?ex.sets.map(s=>({w:s.w,r:s.r,done:false})):[],notes:logs[exId]?.notes||''};
  }
}

function setField(exId, si, field, val, dayId) {
  ensureLog(exId,dayId);
  if (!logs[exId].sets[si]) logs[exId].sets[si]={w:'',r:'',done:false};
  logs[exId].sets[si][field] = val===''?'':(isNaN(+val)?val:+val);
  const s=logs[exId].sets[si];
  const vol=(+s.w||0)*(+s.r||0);
  // Use data attribute selector to avoid nth-child fragility
  const vc=document.querySelector(`[data-volcell="${exId}-${si}"]`);
  if(vc) vc.textContent=vol>0?vol.toLocaleString():'—';
  save('logs',logs);
  updateProgress(plan.days.find(d=>d.id===dayId));
}

function toggleDone(exId, si, dayId) {
  ensureLog(exId,dayId);
  if(!logs[exId].sets[si]) logs[exId].sets[si]={w:'',r:'',done:false};
  logs[exId].sets[si].done=!logs[exId].sets[si].done;
  const btn=document.getElementById('cb-'+exId+'-'+si);
  if(btn) btn.classList.toggle('done',logs[exId].sets[si].done);
  save('logs',logs);
  updateProgress(plan.days.find(d=>d.id===dayId));
}

function updateNotes(exId,val) { if(!logs[exId])logs[exId]={}; logs[exId].notes=val; save('logs',logs); }

function updateProgress(day) {
  if(!day) return;
  let total=0,done=0;
  day.exercises.forEach(ex=>{
    const sets=(logs[ex.id]||{}).sets||ex.sets;
    sets.forEach(s=>{total++;if(s.done)done++;});
  });
  document.getElementById('progFill').style.width=total?Math.round(done/total*100)+'%':'0%';
}

function updateRepRange(exId, dayId, field, val) {
  const day=plan.days.find(d=>d.id===dayId);
  const ex=day?.exercises.find(e=>e.id===exId);
  if(ex) { ex[field]=+val; save('plan',plan); }
  // Update subtitle live
  const sub=document.querySelector(`#ec-${exId} .ex-sub-text`);
  if(sub) sub.textContent=`${(logs[exId]||{sets:ex.sets}).sets?.length||ex.sets.length} sets · ${ex.rMin||6}–${ex.rMax||12} reps`;
}

function addSet(exId,dayId) {
  const day=plan.days.find(d=>d.id===dayId);
  const ex=day.exercises.find(e=>e.id===exId);
  const last=ex.sets[ex.sets.length-1]||{w:'',r:''};
  ex.sets.push({w:last.w,r:last.r});
  ensureLog(exId,dayId);
  logs[exId].sets.push({w:last.w,r:last.r,done:false});
  save('plan',plan); save('logs',logs); renderMain();
}

function removeSet(exId,dayId) {
  const day=plan.days.find(d=>d.id===dayId);
  const ex=day.exercises.find(e=>e.id===exId);
  if(ex.sets.length<=1){toast('Cannot remove last set');return;}
  ex.sets.pop();
  if(logs[exId]&&logs[exId].sets?.length>ex.sets.length) logs[exId].sets.pop();
  save('plan',plan); save('logs',logs); renderMain();
}

function renameEx(exId,dayId,val) {
  const day=plan.days.find(d=>d.id===dayId);
  const ex=day?.exercises.find(e=>e.id===exId);
  if(ex){ex.name=val;save('plan',plan);}
  const nm=document.querySelector(`#ec-${exId} .ex-head-name`);
  if(nm) nm.textContent=val;
}

function changeMuscleProp(exId,dayId,val) {
  const day=plan.days.find(d=>d.id===dayId);
  const ex=day?.exercises.find(e=>e.id===exId);
  if(ex){ex.muscle=val;save('plan',plan);}
  renderSidebar(); renderMain();
}

function removeEx(exId,dayId) {
  const day=plan.days.find(d=>d.id===dayId);
  if(day.exercises.length<=1){toast('Cannot remove last exercise');return;}
  day.exercises=day.exercises.filter(e=>e.id!==exId);
  delete logs[exId];
  save('plan',plan); save('logs',logs); renderSidebar(); renderMain();
}

function addExercise() {
  const day=plan.days.find(d=>d.id===activeDay);
  const newEx={id:'ex_'+Date.now(),name:'New Exercise',muscle:day.pm||'chest',rMin:8,rMax:12,sets:[{w:'',r:''},{w:'',r:''},{w:'',r:''}]};
  day.exercises.push(newEx);
  save('plan',plan); renderSidebar(); renderMain();
  setTimeout(()=>{const c=document.getElementById('ec-'+newEx.id);if(c){c.classList.add('open');c.scrollIntoView({behavior:'smooth',block:'center'});}},60);
}

function openSwap(dayId,exId) {
  swapTarget={dayId,exId};
  const day=plan.days.find(d=>d.id===dayId);
  const ex=day.exercises.find(e=>e.id===exId);
  document.getElementById('swapInput').value=ex?ex.name:'';
  document.getElementById('swapOverlay').classList.add('show');
  setTimeout(()=>document.getElementById('swapInput').select(),80);
}
function closeSwap(){document.getElementById('swapOverlay').classList.remove('show');swapTarget=null;}
function confirmSwap(){if(!swapTarget)return;const v=document.getElementById('swapInput').value.trim();if(!v)return;renameEx(swapTarget.exId,swapTarget.dayId,v);closeSwap();renderMain();toast('Exercise swapped');}
document.getElementById('swapOverlay').addEventListener('click',e=>{if(e.target===e.currentTarget)closeSwap();});
document.getElementById('swapInput').addEventListener('keydown',e=>{if(e.key==='Enter')confirmSwap();if(e.key==='Escape')closeSwap();});

async function advanceWeek() {
  confirm2(
    'Start Next Week?',
    `This will save your current logs and suggest new weights for Week ${plan.week + 1}. This cannot be undone.`,
    async () => {
      const day=plan.days.find(d=>d.id===activeDay); if(!day) return;
      // Snapshot ALL days, not just active
      plan.days.forEach(d => {
        d.exercises.forEach(ex=>{
          const log=logs[ex.id]||{};
          const logged=(log.sets||[]).filter(s=>s.w||s.r);
          if(!exHist[ex.id]) exHist[ex.id]=[];
          if(logged.length>0) exHist[ex.id].push({week:plan.week,exName:ex.name,sets:logged.map(s=>({w:+s.w||0,r:+s.r||0})),vol:totalVol(logged),notes:log.notes||''});
          const sugg=suggest(ex);
          if(sugg) ex.sets=sugg.sets.map(s=>({w:s.w,r:s.r}));
          else if(logged.length>0) ex.sets=logged.map(s=>({w:+s.w||0,r:+s.r||0}));
          logs[ex.id]={};
        });
      });
      plan.week++;
      _tempSwaps = {}; // clear temp swaps on week advance
      await saveTempSwaps();
      document.getElementById('weekTag').textContent='Week '+plan.week;
      await save('plan',plan); await save('logs',logs); await save('exhist',exHist);
      renderSidebar(); renderMain();
      toast('Week '+plan.week+' started');
    }
  );
}

