    phase = null; await savePhase2();
    renderPhaseCard(); renderProjections();
    toast('Phase ended');
  });
}

function renderPhaseCard() {
  if (!document.getElementById('phaseCard')) return;
  if (!phase) {
    document.getElementById('phaseActive').style.display='none';
    document.getElementById('phaseSetup').style.display='block';
    return;
  }
  document.getElementById('phaseActive').style.display='block';
  document.getElementById('phaseSetup').style.display='none';

  const lastBody = [...bodyLog].sort((a,b)=>b.date.localeCompare(a.date))[0]||null;
  const curW = lastBody?.weight || phase.startWeight;
  const startDate = new Date(phase.startDate+'T12:00:00');
  const today2 = new Date();
  const daysElapsed = Math.max(0, Math.round((today2-startDate)/(1000*60*60*24)));
  const weeksElapsed = daysElapsed/7;
  const totalWeeks = phase.durationWeeks;

  // Weekly goal weight = linear interpolation
  const weekGoalW = phase.startWeight + (phase.goalWeight-phase.startWeight)*(Math.min(weeksElapsed+1,totalWeeks)/totalWeeks);
  const totalDelta = phase.goalWeight - phase.startWeight;
  const pct = Math.min(Math.abs(curW-phase.startWeight)/Math.abs(totalDelta||1)*100, 100);

  const typeLabel = phase.type.charAt(0).toUpperCase()+phase.type.slice(1);
  document.getElementById('phaseTitle').textContent = `${typeLabel} · ${phase.startWeight} → ${phase.goalWeight} lb`;
  document.getElementById('phaseProgress').textContent = `${Math.round(weeksElapsed)} of ${totalWeeks} weeks · ${daysElapsed} days elapsed`;
  document.getElementById('phaseWeekGoal').innerHTML = weekGoalW.toFixed(1)+'<span class="stat-box-unit"> lb</span>';
  document.getElementById('phaseCurrentW').innerHTML = curW+'<span class="stat-box-unit"> lb</span>';
  const toGo = (phase.goalWeight - curW);
  document.getElementById('phaseToGo').innerHTML = (toGo>0?'+':'')+toGo.toFixed(1)+'<span class="stat-box-unit"> lb</span>';
  document.getElementById('phaseBar').style.width = pct+'%';
  document.getElementById('phaseBarLabel').textContent = Math.round(pct)+'% complete';
}

