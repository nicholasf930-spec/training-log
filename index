// ═══════════════════════════════════════════════════════
// WEEKLY WEIGHT AVERAGE + PHASE PROGRESS
// ═══════════════════════════════════════════════════════
function getWeekKey(dateStr) {
  const d = new Date(dateStr + 'T12:00:00');
  // ISO week: find Monday of that week
  const day = d.getDay(); // 0=Sun
  const diff = d.getDate() - (day === 0 ? 6 : day - 1);
  const mon = new Date(d.setDate(diff));
  return mon.toISOString().slice(0, 10);
}

function computeWeeklyAverages() {
  const byWeek = {};
  bodyLog.forEach(e => {
    if (!e.weight) return;
    const wk = getWeekKey(e.date);
    if (!byWeek[wk]) byWeek[wk] = [];
    byWeek[wk].push(+e.weight);
  });
  return Object.entries(byWeek)
    .sort(([a],[b]) => a.localeCompare(b))
    .map(([wk, weights]) => ({
      week: wk,
      avg: Math.round(weights.reduce((a,b)=>a+b,0)/weights.length * 10) / 10,
      n: weights.length
    }));
}

function renderPhaseProgress() {
  const el = document.getElementById('phaseProgressContent'); if (!el) return;
  if (!phase) { el.innerHTML = '<div class="chart-empty">No active phase — start one in the Goals tab</div>'; return; }

  const weeklyAvgs = computeWeeklyAverages();
  if (!weeklyAvgs.length) { el.innerHTML = '<div class="chart-empty">Log daily weights to track phase progress</div>'; return; }

  // Build goal line: weekly targets from start → goal
  const phaseStart = new Date(phase.startDate + 'T12:00:00');
  const goalWeeks = weeklyAvgs.map(({week}) => {
    const d = new Date(week + 'T12:00:00');
    const weeksIn = Math.max(0, (d - phaseStart) / (1000*60*60*24*7));
    if (weeksIn > phase.durationWeeks) return null;
    return phase.startWeight + (phase.goalWeight - phase.startWeight) * (weeksIn / phase.durationWeeks);
  });

  const labels = weeklyAvgs.map(({week}) => {
    const d = new Date(week + 'T12:00:00');
    return 'Wk ' + (d.getMonth()+1) + '/' + d.getDate();
  });

  const chartEl = document.getElementById('weeklyAvgChart');
  if (chartEl) {
    buildChart(chartEl, [
      { values: weeklyAvgs.map(w=>w.avg), color: '#f2f2f5', label: 'Actual avg' },
      { values: goalWeeks, color: '#e8954a', dash: true, label: 'Goal' }
    ], { labels, height: 150, padL: 46 });
  }

  // Table
  const tableEl = document.getElementById('weeklyAvgTable');
  if (tableEl) {
    const rows = weeklyAvgs.slice().reverse().map((w, i, arr) => {
      const prev = arr[i+1];
      const delta = prev ? (w.avg - prev.avg).toFixed(1) : null;
      const di = weeklyAvgs.indexOf(weeklyAvgs.find(x=>x.week===w.week));
      const goalW = goalWeeks[di];
      const vs = goalW ? (w.avg - goalW).toFixed(1) : null;
      const d = new Date(w.week + 'T12:00:00');
      return `<tr>
        <td style="color:var(--t2)">Wk ${(d.getMonth()+1)}/${d.getDate()}</td>
        <td style="font-variant-numeric:tabular-nums">${w.avg} lb <span style="font-size:10px;color:var(--t4)">(${w.n}d)</span></td>
        <td style="font-variant-numeric:tabular-nums;color:${delta===null?'var(--t4)':+delta<0?'var(--up)':+delta>0?'var(--danger)':'var(--t3)'}">${delta!==null?(+delta>0?'+':'')+delta+' lb':'—'}</td>
        <td style="font-variant-numeric:tabular-nums;color:${vs===null?'var(--t4)':Math.abs(+vs)<0.5?'var(--up)':'var(--warn)'}">${vs!==null?(+vs>0?'+':'')+vs:'—'}</td>
      </tr>`;
    }).join('');
    tableEl.innerHTML = `<table class="data-table"><thead><tr><th>Week</th><th>Avg Weight</th><th>Change</th><th>vs Goal</th></tr></thead><tbody>${rows}</tbody></table>`;
  }

  el.innerHTML = `
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px">
      <div class="stat-box"><div class="stat-box-label">Phase</div><div class="stat-box-val" style="font-size:13px;text-transform:capitalize">${phase.type}</div></div>
      <div class="stat-box"><div class="stat-box-label">Start</div><div class="stat-box-val">${phase.startWeight}<span class="stat-box-unit"> lb</span></div></div>
      <div class="stat-box"><div class="stat-box-label">Goal</div><div class="stat-box-val">${phase.goalWeight}<span class="stat-box-unit"> lb</span></div></div>
    </div>`;
}

