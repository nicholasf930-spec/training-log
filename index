function saveCurrentMealsAsTemplate() {
  const name = document.getElementById('templateName')?.value?.trim();
  if(!name){toast('Enter a template name');return;}
  const today=getViewingDate();
  const meals=mealLogs[today]||[];
  // Update section label
  const dl=document.getElementById('nutritionDateLabel'); if(dl){const isT=today===todayStr(); const d=new Date(today+'T12:00:00'); dl.textContent=isT?'Today':d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});}
  if(!meals.length){toast('No meals logged today to save');return;}
  mealTemplates.push({id:'mt_'+Date.now(),name,items:meals.map(m=>({name:m.name,cal:m.cal,protein:m.protein||m.p||0}))});
  saveMealTemplates(); toast('Template saved'); renderMealModalTabs();
}

function logTemplate(id) {
  const t=mealTemplates.find(x=>x.id===id); if(!t) return;
  const today=todayStr();
  if(!mealLogs[today]) mealLogs[today]=[];
  t.items.forEach(i=>mealLogs[today].push({name:i.name,cal:i.cal,protein:i.protein}));
  save('meals',mealLogs); renderNutrition(); closeMealModal();
  toast(`Logged ${t.name}`);
}

function deleteTemplate(id) {
  mealTemplates=mealTemplates.filter(t=>t.id!==id);
  saveMealTemplates(); renderMealModalTabs();
}

