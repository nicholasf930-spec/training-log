function calcTDEE(p) {
  const w=+p.weight, h=+p.height, age=+p.age, sex=p.sex||'male', act=+p.activity||1.55;
  if(!w||!h||!age) return null;
  const kg=w*0.4536, cm=h*2.54;
  const bmr=sex==='male'?(10*kg)+(6.25*cm)-(5*age)+5:(10*kg)+(6.25*cm)-(5*age)-161;
  return Math.round(bmr*act);
}

function calcCalGoal(p, tdee) {
  if(!tdee) return null;
  const mode=p.goalMode||'maintain', rate=+p.goalRate||0.5;
  const delta=mode==='lose'?-(rate*3500/7):mode==='gain'?(rate*3500/7):0;
  return Math.round(tdee+delta);
}

function renderNutrition() {
  const today=getViewingDate();
  // Init date input if empty
  const nd=document.getElementById('nutritionDate'); if(nd&&!nd.value) nd.value=todayStr();
  const bd=document.getElementById('inBodyDate'); if(bd&&!bd.value) bd.value=todayStr();
  // Update today tag
  document.getElementById('todayTag').textContent=new Date().toLocaleDateString('en-US',{month:'short',day:'numeric'});

  // Pull latest body data
  const lastBody=[...bodyLog].sort((a,b)=>b.date.localeCompare(a.date))[0]||null;
  const weight=+(lastBody?.weight)||+(profile.weight)||0;
  const bf=+(lastBody?.bf)||+(profile.bf)||0;

  // Stats boxes
  const tdee=calcTDEE({...profile,weight,age:profile.age,height:profile.height});
  const calGoal=calcCalGoal(profile,tdee);
  const protGoal=weight>0?Math.round(weight):null;

  document.getElementById('sbWeight').innerHTML=weight?`${weight}<span class="stat-box-unit"> lb</span>`:'—';
  document.getElementById('sbBF').innerHTML=bf?`${bf}<span class="stat-box-unit"> %</span>`:'—';
  document.getElementById('sbTDEE').innerHTML=tdee?`${tdee}<span class="stat-box-unit"> kcal</span>`:'—';

  // Calorie meter
  const meals=mealLogs[today]||[];
  const totCal=meals.reduce((a,m)=>a+(+m.cal||0),0);
  const totP=meals.reduce((a,m)=>a+(+(m.protein||m.p)||0),0);
  const totC=0;
  const totF=0;

  const calPct=calGoal?Math.min(totCal/calGoal,1):0;
  document.getElementById('mCalVal').textContent=totCal.toLocaleString();
  document.getElementById('mCalGoal').textContent=calGoal?`/ ${calGoal.toLocaleString()} goal`:'/ set goal below';
  document.getElementById('mCalBar').style.width=(calPct*100)+'%';
  document.getElementById('mCalBar').style.background=calPct>1?'#b85868':'#f0f0f4';
  const rem=calGoal?calGoal-totCal:null;
  document.getElementById('mCalSub').textContent=rem!=null?(rem>=0?`${rem.toLocaleString()} remaining`:`${Math.abs(rem).toLocaleString()} over budget`):'Log meals to begin';

  // Macro bars
  document.getElementById('mP').textContent=totP+'g';
  document.getElementById('mC').textContent=totC+'g';
  document.getElementById('mF').textContent=totF+'g';
  if(calGoal){
    document.getElementById('mPBar').style.width=Math.min((totP*4)/calGoal,1)*100+'%';
    document.getElementById('mCBar').style.width=Math.min((totC*4)/calGoal,1)*100+'%';
    document.getElementById('mFBar').style.width=Math.min((totF*9)/calGoal,1)*100+'%';
  }

  // Protein meter
  const protPct=protGoal?Math.min(totP/protGoal,1):0;
  document.getElementById('mProtVal').textContent=totP;
  document.getElementById('mProtGoal').textContent=protGoal?`/ ${protGoal}g target`:'/ log weight below';
  document.getElementById('mProtBar').style.width=(protPct*100)+'%';
  document.getElementById('mProtBar').style.background=protPct>=1?'#4a9e62':'#3a9e98';
  document.getElementById('mProtSub').textContent=protGoal&&totP<protGoal?`${protGoal-totP}g to go`:(protGoal&&totP>=protGoal?'Target reached':'1g per lb bodyweight');

  // Meals list
  renderMeals();

  // Body inputs
  if(weight) document.getElementById('inWeight').value=weight;
  if(bf) document.getElementById('inBF').value=bf;

  // Goal settings
  ['lose','maintain','gain'].forEach(m=>{
    document.getElementById('gt-'+m)?.classList.toggle('active',profile.goalMode===m);
  });
  if(profile.goalRate) document.getElementById('goalRate').value=profile.goalRate;
  if(profile.activity) document.getElementById('activitySel').value=profile.activity;
  if(profile.age)    document.getElementById('inAge').value=profile.age;
  if(profile.height) document.getElementById('inHeight').value=profile.height;
  if(profile.sex)    document.getElementById('inSex').value=profile.sex;

  // Summary
  if(tdee&&calGoal) {
    const mode=profile.goalMode||'maintain';
    const rate=+profile.goalRate||0.5;
    const modeLabel=mode==='lose'?`lose ~${rate} lb/wk`:mode==='gain'?`gain ~${rate} lb/wk`:'maintain weight';
    document.getElementById('calSummary').textContent=`TDEE ${tdee.toLocaleString()} kcal · Goal: ${modeLabel} · Target ${calGoal.toLocaleString()} kcal/day`;
  } else {
    document.getElementById('calSummary').textContent='Enter your age, height, and sex to calculate TDEE.';
  }

  // Phase and projections now in Goals panel
}

function renderMeals() {
  const meals=mealLogs[todayStr()]||[];
  const el=document.getElementById('mealsList');
  if(!meals.length){el.innerHTML='<div style="font-size:12px;color:var(--t4);padding:4px 0">No meals logged today</div>';return;}
  el.innerHTML=meals.map((m,i)=>{
    const prot=m.protein||m.p||0;
    return `<div class="meal-item">
      <div class="meal-item-info">
        <div class="meal-item-name">${esc(m.name)}</div>
        <div class="meal-item-macros">${prot}g protein</div>
      </div>
      <div class="meal-item-cal">${(+m.cal||0).toLocaleString()}</div>
      <button class="meal-del" onclick="delMeal(${i})" aria-label="Delete meal">&#x2715;</button>
    </div>`;
  }).join('');
}
function delMeal(i) {
  const t=todayStr();
  if(!mealLogs[t]) return;
  mealLogs[t].splice(i,1);
  save('meals',mealLogs); renderNutrition();
}

function addMealEntry(meal) {
  const t=todayStr();
  if(!mealLogs[t]) mealLogs[t]=[];
  if(meal.p!==undefined && !meal.protein) meal.protein=meal.p;
  mealLogs[t].push(meal);
  save('meals',mealLogs); renderNutrition();
}

function logBody() {
  const w=document.getElementById('inWeight').value;
  const bf=document.getElementById('inBF').value;
  const dateEl=document.getElementById('inBodyDate');
  const dateVal=dateEl&&dateEl.value?dateEl.value:todayStr();
  if(!w&&!bf){toast('Enter weight or BF%');return;}
  const entry={date:dateVal,weight:+w||null,bf:+bf||null};
  bodyLog=bodyLog.filter(e=>e.date!==dateVal);
  bodyLog.push(entry);
  bodyLog.sort((a,b)=>a.date.localeCompare(b.date));
  if(dateVal===todayStr()){
    if(w) profile.weight=+w;
    if(bf) profile.bf=+bf;
    save('profile',profile);
  }
  save('bodylog',bodyLog);
  updateNutritionMeters();
  const d=new Date(dateVal+'T12:00:00');
  const label=dateVal===todayStr()?'today':d.toLocaleDateString('en-US',{month:'short',day:'numeric'});
  toast('Logged for '+label);
  document.getElementById('inWeight').value='';
  document.getElementById('inBF').value='';
}

function setGoalMode(mode) {
  profile.goalMode=mode;
  ['lose','maintain','gain'].forEach(m=>document.getElementById('gt-'+m)?.classList.toggle('active',mode===m));
  document.getElementById('goalRateWrap').style.display=mode==='maintain'?'none':'grid';
  saveGoals();
}

function saveGoals() {
  profile.goalRate=+document.getElementById('goalRate').value||0.5;
  profile.activity=+document.getElementById('activitySel').value||1.55;
  const ageV=document.getElementById('inAge').value; if(ageV) profile.age=+ageV;
  const htV=document.getElementById('inHeight').value; if(htV) profile.height=+htV;
  profile.sex=document.getElementById('inSex').value||profile.sex;
  save('profile',profile);
  updateNutritionMeters();
  renderGoalResult();
}

